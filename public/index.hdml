          <select style="width:100%;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:10px 14px;font-size:14px;color:#fff;outline:none;font-family:inherit;">
            <option value="" style="background:#1e293b">Select a topic</option>
            <option value="feedback" style="background:#1e293b">Product feedback</option>
            <option value="bug" style="background:#1e293b">Report a bug</option>
            <option value="feature" style="background:#1e293b">Feature request</option>
            <option value="other" style="background:#1e293b">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label>Message</label>
